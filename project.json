{
  "name": "workspace",
  "$schema": "./node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run backend:serve",
          "nx run frontend:serve"
        ],
        "parallel": true
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run frontend:build",
          "nx run backend:build"
        ],
        "parallel": false
      }
    }
  },
  "tags": []
}
